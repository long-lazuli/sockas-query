{
  "name": "sockas-query-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "dev": "concurrently --names server,frontend --prefix-colors cyan,yellow \"pnpm --filter sockas-query-chat-server dev\" \"pnpm --filter react-sockas-example dev\"",
    "test:lib": "pnpm -r --filter './packages/*' test:lib",
    "test:types": "pnpm -r --filter './packages/*' test:types",
    "test:eslint": "pnpm -r --filter './packages/*' test:eslint"
  },
  "devDependencies": {
    "@cspell/eslint-plugin": "^10.0.0",
    "@tanstack/eslint-config": "^0.4.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.4.0"
  }
}
